# ═══════════════════════════════════════════════════════════════════════════════
# alsaqi-backend — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file documents ALL environment variables used in source code.
# Copy to .env and replace example values with real production credentials.
#
# Legend:
#   [REQUIRED] — Server will NOT start without this variable in production
#   [OPTIONAL] — Server works with the documented default value
#
# ═══════════════════════════════════════════════════════════════════════════════


# ─── SERVER ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Application environment mode — set to "production" for production deployments
# Type: string (development | production | test)
# Default: development
NODE_ENV=production

# [OPTIONAL] HTTP server listening port
# Type: numeric
# Default: 3000
PORT=3000

# [REQUIRED] Comma-separated list of allowed CORS origins for cross-origin requests
# Type: string (comma-separated URLs)
CORS_ORIGIN=https://app.example.com,https://admin.example.com

# [OPTIONAL] Directory path for user-uploaded files
# Type: path
# Default: ./uploads
UPLOAD_DIR=/app/uploads

# [OPTIONAL] Logging level controlling verbosity of application logs
# Type: log-level (error | warn | info | debug)
# Default: info
LOG_LEVEL=info


# ─── DATABASE ─────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# Type: url (postgresql://user:pass@host:port/dbname)
DATABASE_URL=postgresql://alsaqi_user:strong-password-here@db.example.com:5432/alsaqi_production?sslmode=require

# [OPTIONAL] Path to CA certificate file for database SSL verification
# Type: path
DB_SSL_CA_PATH=/etc/ssl/certs/rds-ca-bundle.pem

# [OPTIONAL] Whether to reject unauthorized SSL connections to database
# Type: boolean (true | false)
# Default: true
DB_SSL_REJECT_UNAUTHORIZED=true


# ─── AUTHENTICATION ───────────────────────────────────────────────────────────

# [REQUIRED] JWT signing secret — must be a strong random value (minimum 64 characters)
# Type: string (min 64 chars)
JWT_SECRET=replace-with-64-or-more-random-characters-generated-by-openssl-rand-base64-48

# [OPTIONAL] RSA private key in PEM format for asymmetric JWT signing (auto-generated if not provided)
# Type: pem-key
# Note: Use literal \n for newlines in single-line format, or mount as file
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAK...\n-----END RSA PRIVATE KEY-----

# [OPTIONAL] RSA public key in PEM format for JWT verification (auto-generated if not provided)
# Type: pem-key
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgk...\n-----END PUBLIC KEY-----


# ─── ENCRYPTION ───────────────────────────────────────────────────────────────

# [REQUIRED] Storage encryption secret for client-side encrypted data (minimum 32 characters)
# Type: string (min 32 chars)
VITE_STORAGE_SECRET=replace-with-32-or-more-random-characters-here

# [REQUIRED] HMAC secret for network request signing between frontend and backend
# Type: string
VITE_NETWORK_SECRET=replace-with-strong-hmac-secret-value

# [OPTIONAL] AES encryption key for file-at-rest encryption (encryption disabled if not set)
# Type: string
FILE_ENCRYPTION_KEY=replace-with-aes-encryption-key-minimum-32-chars

# [OPTIONAL] Encryption key for 2FA TOTP secrets (falls back to FILE_ENCRYPTION_KEY if not set)
# Type: string
TOTP_ENCRYPTION_KEY=replace-with-totp-specific-encryption-key

# [REQUIRED] Dedicated secret for signing/verifying secure file-access URLs (minimum 32 characters)
# Type: string (min 32 chars)
FILE_ACCESS_SECRET=replace-with-32-or-more-random-characters-for-file-access-url-signing


# ─── CACHE / REDIS ────────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL for caching, rate limiting, and BullMQ job queues
# Type: url (redis://host:port or rediss://host:port for TLS)
REDIS_URL=redis://redis.example.com:6379

# [REQUIRED] Redis authentication password — must be a strong random value
# Type: string
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=<generate-strong-random-password>


# ─── BACKUP ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Persistent data directory for RSA keys and application data
# Type: path
# Default: ./data
DATA_DIR=/app/data

# [OPTIONAL] Directory for storing database backup files
# Type: path
# Default: ./backups
BACKUP_DIR=/app/backups

# [OPTIONAL] Maximum number of backup files to retain before oldest is deleted
# Type: numeric
# Default: 7
MAX_BACKUPS=7

# [OPTIONAL] Number of days to retain backup files before automatic deletion
# Type: numeric
# Default: 30
BACKUP_RETENTION_DAYS=30

# [OPTIONAL] Whether to encrypt database backup files at rest
# Type: boolean (true | false)
# Default: false
ENCRYPT_BACKUPS=false

# [OPTIONAL] Number of months to retain audit trail table partitions
# Type: numeric
# Default: 24
AUDIT_TRAIL_RETENTION_MONTHS=24


# ─── EXTERNAL INTEGRATIONS ───────────────────────────────────────────────────

# [OPTIONAL] n8n automation webhook URL for workflow triggers (graceful degradation if not set)
# Type: url (https://...)
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/alsaqi-events

# [OPTIONAL] API key for authenticating requests to n8n webhook
# Type: string
N8N_WEBHOOK_API_KEY=replace-with-n8n-api-key
