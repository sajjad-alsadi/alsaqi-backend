{
    "name": "alsaqi-backend",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "tsx --watch src/main.ts",
        "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest --run",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@alsaqi/shared": "file:./packages/shared",
        "@aws-sdk/client-s3": "^3.1064.0",
        "@aws-sdk/s3-request-presigner": "^3.1064.0",
        "@electric-sql/pglite": "^0.4.1",
        "@types/qrcode": "^1.5.6",
        "@types/sanitize-html": "^2.16.1",
        "axios": "^1.17.0",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.78.0",
        "compression": "^1.8.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-fileupload": "^1.5.2",
        "express-rate-limit": "^8.3.1",
        "generic-pool": "^3.9.0",
        "handlebars": "^4.7.9",
        "helmet": "^8.2.0",
        "ioredis": "^5.11.1",
        "jsonwebtoken": "^9.0.3",
        "magika": "^1.0.0",
        "node-cron": "^4.2.1",
        "otpauth": "^9.5.1",
        "pg": "^8.20.0",
        "prom-client": "^15.1.3",
        "puppeteer": "^25.1.0",
        "qrcode": "^1.5.4",
        "sanitize-html": "^2.17.4",
        "uuid": "^13.0.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-fileupload": "^1.5.1",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^25.4.0",
        "@types/node-cron": "^3.0.0",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.18.1",
        "esbuild": "^0.28.0",
        "fast-check": "^4.8.0",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3",
        "vitest": "^3.2.1"
    }
}
