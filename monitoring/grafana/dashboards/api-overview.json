{
  "__comment": "Grafana dashboard — production-launch-readiness (Requirement 13.2). Panels: service up/down, request error rate %, DB connection pool metrics. refresh <= 60s.",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["alsaqi", "production-launch-readiness"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Data source",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "ALSAQI API — Overview",
  "uid": "alsaqi-api-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Service Up / Down",
      "type": "stat",
      "description": "up metric for the alsaqi-api scrape job. 1 = up, 0 = down.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "up{job=\"alsaqi-api\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Error Rate (%)",
      "type": "timeseries",
      "description": "Percentage of HTTP requests resulting in errors (5xx / unhandled exceptions) over a 5m window.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * (sum(rate(alsaqi_http_errors_total{job=\"alsaqi-api\"}[5m])) / clamp_min(sum(rate(alsaqi_http_request_duration_seconds_count{job=\"alsaqi-api\"}[5m])), 1))",
          "legendFormat": "error rate %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "description": "Database connection pool metrics: total, idle, used, and waiting connections.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "alsaqi_db_pool_total_count{job=\"alsaqi-api\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "alsaqi_db_pool_idle_count{job=\"alsaqi-api\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "alsaqi_db_pool_used_count{job=\"alsaqi-api\"}",
          "legendFormat": "used",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "alsaqi_db_pool_waiting_count{job=\"alsaqi-api\"}",
          "legendFormat": "waiting",
          "refId": "D"
        }
      ]
    },
    {
      "id": 4,
      "title": "DB Pool Waiting (queued requests)",
      "type": "stat",
      "description": "Requests queued waiting for a DB connection. Sustained > 0 indicates pool pressure.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "alsaqi_db_pool_waiting_count{job=\"alsaqi-api\"}",
          "legendFormat": "waiting",
          "refId": "A"
        }
      ]
    }
  ]
}
